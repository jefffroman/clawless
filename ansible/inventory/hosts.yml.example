# Example only — the real hosts.yml is generated by scripts/sync-inventory.py.
#
# After `tofu apply`, run:
#   python3 scripts/sync-inventory.py
#
# That script reads `tofu output -json` and writes:
#   - ansible/inventory/hosts.yml       (public IPs, client slugs)
#   - ansible/host_vars/<slug>/vars.yml (AWS keys from Terraform, gateway token)
#
# Both files are gitignored. Do not edit them manually.
#
# Variable reference:
#   openclaw_aws_access_key_id / _secret_access_key:
#     IAM credentials for the per-client Bedrock user created by Terraform.
#     Allows the gateway to call Bedrock without exposing account-level keys.
#   openclaw_gateway_token:
#     Auth token for the OpenClaw gateway. Generated by sync-inventory.py
#     on first run and preserved across subsequent runs. We set this value —
#     OpenClaw uses whatever token is configured in its env file.
---
all:
  children:
    clawless_nodes:
      vars:
        ansible_user: ubuntu
        ansible_ssh_private_key_file: ~/.ssh/id_rsa
        openclaw_bedrock_region: us-east-1
      hosts:
        acme:
          ansible_host: 1.2.3.4     # from tofu output client_public_ips
          client_slug: acme
          # sensitive vars loaded automatically from host_vars/acme/vars.yml
