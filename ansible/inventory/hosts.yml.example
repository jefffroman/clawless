# Inventory is not used during normal operations.
# Terraform's null_resource local-exec passes the host IP inline:
#   ansible-playbook -i "<ip>," playbooks/provision.yml -e "..."
#
# This file is only useful for manual re-runs against a specific host, e.g.:
#   ansible-playbook -i inventory/hosts.yml playbooks/provision.yml \
#     -l acme \
#     -e "openclaw_gateway_token=<token>" \
#     -e "openclaw_bedrock_region=us-east-1"
#
# AWS credentials are NOT passed here — SSM provides them automatically
# on the instance via rotating temporary credentials.
---
all:
  children:
    clawless_nodes:
      vars:
        ansible_user: ubuntu
        ansible_ssh_private_key_file: ~/.ssh/id_rsa
        openclaw_bedrock_region: us-east-1
      hosts:
        acme:
          ansible_host: 1.2.3.4  # tofu output client_public_ips
          client_slug: acme
