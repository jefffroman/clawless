#!/bin/bash
# Self-sleep: sets this agent's /active parameter to "false" and invokes
# the lifecycle Step Functions workflow to snapshot and destroy this instance.
#
# Deployed by Ansible with the agent's slug and SFN ARN baked in.
# The agent (or an MCP tool) just runs `clawless-sleep` — no SSM path
# or SFN ARN knowledge needed.

set -euo pipefail

SLUG="{{ agent_slug }}"
PARAM="/clawless/clients/${SLUG}/active"
REGION="{{ openclaw_bedrock_region }}"
SFN_ARN="{{ lifecycle_sfn_arn }}"
WAKE_LISTENER_URL="{{ wake_listener_url }}"

echo "Putting this agent to sleep (${SLUG})..."

# ── Redirect Telegram webhook to wake listener ──────────────────────────────
{% if agent_channel | lower == "telegram" %}
AGENT_CONFIG=$(aws ssm get-parameter \
  --name "/clawless/clients/${SLUG}" \
  --with-decryption \
  --query 'Parameter.Value' \
  --output text \
  --region "$REGION" 2>/dev/null || true)

BOT_TOKEN=$(echo "$AGENT_CONFIG" | jq -r '.channel_config.botToken // empty')
RESOURCE_SLUG=$(echo "$SLUG" | tr '/' '-')

if [ -n "$BOT_TOKEN" ] && [ -n "$WAKE_LISTENER_URL" ]; then
  echo "Setting Telegram webhook to wake listener..."
  curl -sf -X POST "https://api.telegram.org/bot${BOT_TOKEN}/setWebhook" \
    -d "url=${WAKE_LISTENER_URL}" \
    -d "secret_token=${RESOURCE_SLUG}" \
    -d "allowed_updates=[\"message\"]" \
    >/dev/null && echo "Webhook set." || echo "WARNING: setWebhook failed"
fi
{% endif %}

# ── Set /active=false and trigger lifecycle ──────────────────────────────────
aws ssm put-parameter \
  --name "$PARAM" \
  --type String \
  --overwrite \
  --value "false" \
  --region "$REGION" >/dev/null

SFN_INPUT=$(jq -cn \
  --arg name "/clawless/clients/${SLUG}" \
  --arg time "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  '{event_id: (now | tostring), time: $time, name: $name, operation: "Update"}')

aws stepfunctions start-execution \
  --state-machine-arn "$SFN_ARN" \
  --input "$SFN_INPUT" \
  --region "$REGION" >/dev/null

echo "Sleep triggered. This instance will be snapshotted and shut down shortly."
