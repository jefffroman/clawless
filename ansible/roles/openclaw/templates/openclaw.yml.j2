# openclaw.yml — managed by Ansible. Do not edit manually.
# Generated: {{ ansible_date_time.iso8601 }}

gateway:
  # Bound to loopback only. Port {{ openclaw_gateway_port }} is intentionally
  # closed in the Lightsail firewall. Channel integrations (Telegram, etc.)
  # reach the gateway via their outbound connections, not inbound on this port.
  host: "{{ openclaw_gateway_host }}"
  port: {{ openclaw_gateway_port }}

bedrock:
  region: "{{ openclaw_bedrock_region }}"
  default_model: "{{ openclaw_default_model }}"
  # Credentials are NOT here — they flow via EnvironmentFile (openclaw.env).

logging:
  level: info
  format: json
