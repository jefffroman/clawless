#!/bin/bash
# Self-pause: sets this agent's /active parameter to "false", triggering
# the lifecycle Lambda to snapshot and destroy this instance.
#
# Deployed by Ansible with the agent's slug baked in. The agent (or an
# MCP tool) just runs `clawless-pause-self` — no SSM path knowledge needed.

set -euo pipefail

PARAM="/clawless/clients/{{ agent_slug }}/active"
REGION="{{ openclaw_bedrock_region }}"

echo "Pausing this agent ({{ agent_slug }})..."
aws ssm put-parameter \
  --name "$PARAM" \
  --type String \
  --overwrite \
  --value "false" \
  --region "$REGION" >/dev/null

echo "Pause triggered. This instance will be snapshotted and shut down shortly."
