#!/bin/bash
# Wake greeting: runs on resume (not first provision) after the gateway is up.
# Checks DynamoDB for a queued wake message; if found, replays it via the
# OpenClaw CLI. Otherwise sends a default greeting.
#
# Deployed by Ansible with agent slug, region, and table name baked in.

set -euo pipefail

SLUG="{{ agent_slug }}"
REGION="{{ openclaw_bedrock_region }}"
TABLE="{{ wake_messages_table_name }}"
ENV_FILE="/etc/openclaw/openclaw.env"
GATEWAY="http://127.0.0.1:18789"
MAX_WAIT=120  # seconds to wait for gateway health

# ── Source gateway token ──────────────────────────────────────────────────────
if [ -f "$ENV_FILE" ]; then
  # shellcheck disable=SC1090
  set -a; source "$ENV_FILE"; set +a
fi

# ── Wait for gateway ─────────────────────────────────────────────────────────
echo "Waiting for OpenClaw gateway..."
elapsed=0
while ! curl -sf "${GATEWAY}/health" >/dev/null 2>&1; do
  sleep 5
  elapsed=$((elapsed + 5))
  if [ "$elapsed" -ge "$MAX_WAIT" ]; then
    echo "ERROR: gateway not healthy after ${MAX_WAIT}s — skipping wake greeting" >&2
    exit 1
  fi
done
echo "Gateway healthy after ${elapsed}s."

# ── Read agent config from SSM ───────────────────────────────────────────────
AGENT_CONFIG=$(aws ssm get-parameter \
  --name "/clawless/clients/${SLUG}" \
  --with-decryption \
  --query 'Parameter.Value' \
  --output text \
  --region "$REGION" 2>/dev/null || true)

if [ -z "$AGENT_CONFIG" ]; then
  echo "ERROR: could not read agent config from SSM" >&2
  exit 1
fi

CHANNEL=$(echo "$AGENT_CONFIG" | jq -r '.agent_channel // empty')
PEER_ID=$(echo "$AGENT_CONFIG" | jq -r '.channel_config.allowFrom[0] // empty')

if [ -z "$CHANNEL" ] || [ -z "$PEER_ID" ]; then
  echo "WARNING: no channel or peer ID configured — skipping wake greeting" >&2
  exit 0
fi

# ── Check DynamoDB for queued wake message ───────────────────────────────────
WAKE_ITEM=$(aws dynamodb get-item \
  --table-name "$TABLE" \
  --key "{\"slug\": {\"S\": \"${SLUG}\"}}" \
  --region "$REGION" \
  --output json 2>/dev/null || echo '{}')

WAKE_MSG=$(echo "$WAKE_ITEM" | jq -r '.Item.message.S // empty')

if [ -n "$WAKE_MSG" ]; then
  echo "Found queued wake message — replaying..."
  # Delete the message first (idempotent, avoids replay on restart)
  aws dynamodb delete-item \
    --table-name "$TABLE" \
    --key "{\"slug\": {\"S\": \"${SLUG}\"}}" \
    --region "$REGION" >/dev/null 2>&1 || true

  openclaw agent \
    --to "$PEER_ID" \
    --message "$WAKE_MSG" \
    --deliver \
    --channel "$CHANNEL"
else
  echo "No queued message — sending default greeting..."
  openclaw agent \
    --to "$PEER_ID" \
    --message "Hello {{ agent_name }}" \
    --deliver \
    --channel "$CHANNEL"
fi

echo "Wake greeting sent."
