aws_region                  = "us-east-1"
replica_region              = "us-east-2"  # DR replica for backup bucket; should differ from aws_region
lightsail_availability_zone = "us-east-1a"
lightsail_bundle_id         = "medium_3_0"
lightsail_blueprint_id      = "openclaw"   # verify exact ID in AWS Lightsail console

clients = {
  acme = {
    display_name = "Acme Corp"
  }
}

tags = {
  Project   = "clawless"
  ManagedBy = "terraform"
  Env       = "production"
}
